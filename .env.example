# Inoreader News Classifier Environment Configuration
# Copy this file to .env and fill in your actual credentials

# Inoreader Account Credentials
# You need a regular Inoreader account (not just OAuth login)
INOREADER_EMAIL=your_email@example.com
INOREADER_PASSWORD=your_password

# Optional: Application identification
INOREADER_APP_ID=InoreaderNewsClassifier
INOREADER_APP_KEY=

# Optional: Database configuration
# DATABASE_PATH=data/news_classifier.db

# Optional: Logging configuration
# LOG_LEVEL=INFO
# LOG_FILE=logs/news_classifier.log

# Optional: Model configuration
# MAX_FEATURES=10000
# MIN_TEXT_LENGTH=50